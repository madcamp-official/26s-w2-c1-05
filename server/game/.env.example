# PostgreSQL (없으면 DB 필요한 엔드포인트가 503 — WS 릴레이·LLM 프록시는 동작)
DATABASE_URL=postgresql://yeoboseyo:yeoboseyo@localhost:5432/yeoboseyo

# 소셜 로그인 (auth.py) — JWT_SECRET은 임의의 긴 랜덤 문자열 (필수)
JWT_SECRET=
# 프로바이더 콜백이 돌아올 공개 주소 (기본값: 터널 도메인)
PUBLIC_BASE_URL=https://graceheeseo.madcamp-kaist.org
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# 카카오 이메일 동의항목을 콘솔에서 안 켰으면 빈 값으로 두기 (기본 account_email)
# KAKAO_SCOPE=

# LLM 프록시 (규칙 #4: API 키는 서버에만)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# vLLM (Qwen3-14B) 준비되면 설정 — 보스 대화·인크리멘탈 심판이 이쪽으로 감
VLLM_BASE_URL=
VLLM_MODEL=Qwen/Qwen3-14B-AWQ
# 데모 보험: gemini로 설정 시 전 태스크 Gemini 강제
LLM_FALLBACK=

# 데스크톱 STT 릴레이(/ws/stt)가 중계할 로컬 whisper 주소 (기본값이면 생략 가능)
WHISPER_LOCAL_URL=ws://localhost:8765

# 보스전 TTS (tts.py) — 우선순위: Qwen(vLLM-Omni) → Google → 503(클라 OS TTS 폴백)
# camp-3의 vLLM-Omni 서빙 주소 (tmux omni 세션, 로컬 개발 시 빈 값이면 스킵)
QWEN_TTS_URL=http://localhost:8802
# GCP 콘솔에서 Cloud Text-to-Speech API 활성화 + API 키 발급 필요 (결제계정 등록 필수,
# 무료 한도 내 사용 시 과금 없음: Chirp3 HD/Neural2 각 100만자/월) — 폴백용, 선택
GOOGLE_TTS_API_KEY=
